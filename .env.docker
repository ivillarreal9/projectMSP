APP_NAME=projectMSP
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080

APP_LOCALE=es
APP_FALLBACK_LOCALE=es

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_LEVEL=error

# ─── BASE DE DATOS (MySQL en Docker) ───
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=projectmsp
DB_USERNAME=projectmsp
DB_PASSWORD=secret_change_me

# ─── SESIÓN / CACHÉ / COLAS ───
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database

# ─── FILESYSTEM ───
FILESYSTEM_DISK=local

# ─── BROWSERSHOT (paths en Linux dentro del contenedor) ───
BROWSERSHOT_CHROME_PATH=/usr/bin/chromium
BROWSERSHOT_NODE_PATH=/usr/bin/node
BROWSERSHOT_NPM_PATH=/usr/bin/npm

# ─── ANTHROPIC ───
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── ODOO ───
ODOO_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_API_KEY=

# ─── AZURE / SHAREPOINT ───
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
SHAREPOINT_SITE_URL=
SHAREPOINT_FOLDER=
SHAREPOINT_FILE=
SHAREPOINT_FOLDER_ID=

# ─── MSP MANAGER ───
MSP_USERNAME=
MSP_PASSWORD=
MSP_BASE_URL=

# ─── SENDGRID ───
SENDGRID_API_KEY=

VITE_APP_NAME="${APP_NAME}"
